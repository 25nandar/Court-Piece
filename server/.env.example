# Port the server listens on. Render sets this automatically in production;
# locally it defaults to 3001 if unset.
PORT=3001

# Allowed browser origin(s) for CORS / Socket.io. Comma-separate multiple.
# Leave unset (or '*') to allow all origins. In production set this to your
# Vercel URL, e.g.:
#   CLIENT_ORIGIN=https://court-piece.vercel.app
CLIENT_ORIGIN=*
